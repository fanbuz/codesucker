{
  "name": "@codesucker/app",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "main": "out/main/index.js",
  "build": {
    "appId": "com.fanbuz.codesucker",
    "productName": "CodeSucker",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "test": "tsx test/job-controller.ts && tsx test/worker-pool.ts",
    "test:workers": "tsx test/worker-integration.ts",
    "perf": "tsx test/performance.ts",
    "start": "electron-vite preview"
  },
  "dependencies": {
    "@codesucker/core": "*",
    "chardet": "^2.0.0",
    "docx": "^8.5.0",
    "fast-glob": "^3.3.2",
    "iconv-lite": "^0.6.3",
    "ignore": "^5.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^43.2.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
